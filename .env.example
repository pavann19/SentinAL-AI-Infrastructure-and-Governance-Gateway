# SentinAL Environment Configuration Example
# Copy this file to .env and adjust values for your environment.

# --- Security Thresholds ---
# Adjust these based on desired sensitivity (0.0 to 1.0)
SEMANTIC_THRESHOLD_HIGH=0.48
SEMANTIC_THRESHOLD_MEDIUM=0.22
EDUCATIONAL_THRESHOLD=0.45
DOMAIN_THRESHOLD=0.22
CACHE_SIMILARITY_THRESHOLD=0.95
META_INTENT_THRESHOLD=0.40

# --- Execution Environment ---
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral
EMBEDDING_MODEL=all-mpnet-base-v2

# --- File Paths ---
# If running from a different directory, use absolute paths
POLICY_FILE=policies.json
POLICY_RULES_FILE=policy_rules.json
